# ============================================
# 本地开发用 (Node.js)
# ============================================
# 数据库连接 (Supabase PostgreSQL - Session Pooler)
DATABASE_URL=postgresql://postgres.[项目ID]:[密码]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ============================================
# Cloudflare Workers 用 (通过 wrangler secret put 设置)
# ============================================
# Supabase URL (在 Settings -> API 中获取)
SUPABASE_URL=https://xxx.supabase.co

# Supabase Anon Key (在 Settings -> API 中获取)
SUPABASE_ANON_KEY=eyJhbGci...

# ============================================
# S3/R2 图床配置 (Cloudflare R2 兼容 S3 API)
# ============================================
# 本地脚本使用 S3_ 前缀的变量
S3_ENDPOINT=https://账户ID.r2.cloudflarestorage.com
S3_BUCKET=yy-gallery
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=auto
S3_PUBLIC_URL=https://pub-xxx.r2.dev

# ============================================
# 地图服务 Token (可选)
# ============================================
MAPBOX_TOKEN=your-mapbox-token
